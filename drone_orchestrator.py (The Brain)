License: GNU GPL v3.0
Authors: Noah & Partners
"""

class DroneOrchestrator:
    def __init__(self, min_safe_distance=0.5, max_velocity=3.0):
        """
        :param min_safe_distance: Minimum distance between drones to prevent collision (meters).
        :param max_velocity: Maximum allowed speed for drones (m/s).
        """
        self.walker = WalkerSoul()
        self.min_safe_distance = min_safe_distance
        self.max_velocity = max_velocity
        self.prev_positions = None

    def check_safety(self, current_pos_dict):
        """ Checks if drones are too close to each other (Noah's Shield Logic) """
        keys = list(current_pos_dict.keys())
        for i in range(len(keys)):
            for j in range(i + 1, len(keys)):
                p1 = np.array(current_pos_dict[keys[i]])
                p2 = np.array(current_pos_dict[keys[j]])
                distance = np.linalg.norm(p1 - p2)
                
                if distance < self.min_safe_distance:
                    # Risk detected: In a real scenario, this would trigger an emergency separation
                    print(f"WARNING: Collision Risk between {keys[i]} and {keys[j]}! Distance: {distance:.2f}m")
                    return False
        return True

    def calculate_velocity(self, current_pos_dict, dt):
        """ Ensures the drones do not exceed physical speed limits """
        if self.prev_positions is None:
            return True
        
        for key in current_pos_dict:
            p1 = np.array(self.prev_positions[key])
            p2 = np.array(current_pos_dict[key])
            velocity = np.linalg.norm(p2 - p1) / dt
            
            if velocity > self.max_velocity:
                print(f"LIMIT: {key} velocity ({velocity:.2f} m/s) exceeds max limit!")
                return False
        return True

    def process_frame(self, t, dt=0.1):
        """ Processes one frame of flight data """
        positions = self.walker.get_positions(t)
        
        # 1. Safety Check (Collision)
        is_safe = self.check_safety(positions)
        
        # 2. Physics Check (Velocity)
        is_physical = self.calculate_velocity(positions, dt)
        
        if is_safe and is_physical:
            self.prev_positions = positions
            return positions, "COMMAND_READY"
        else:
            return positions, "COMMAND_REJECTED_SAFETY_LOCK"

if __name__ == "__main__":
    # Internal validation of the Brain logic
    brain = DroneOrchestrator(min_safe_distance=0.4)
    print("DroneOrchestrator: Initializing flight safety checks...")
    
    # Test a single frame
    pos, status = brain.process_frame(t=1.0)
    print(f"Status at 1.0s: {status}")
